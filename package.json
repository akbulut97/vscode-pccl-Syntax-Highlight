{
  "name": "afsa-pccl",
  "displayName": "PCCL",
  "description": "Language support for the AFSA ROBOTICS PCCL",
  "version": "1.3.0",
  "publisher": "azizhanakbulut",
  "icon": "resources/pccl_icon.webp",
  "repository": {
    "type": "git",
    "url": "https://github.com/akbulut97/vscode-pccl-Syntax-Highlight.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "main": "./client/out/extension",
  "contributes": {
    "languages": [
      {
        "id": "pccl",
        "aliases": [
          "PCCL",
          "pccl"
        ],
        "extensions": [
          ".pcc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "pccl",
        "path": "./snippets/pccl.code-snippets"
      }
    ],
    "grammars": [
      {
        "language": "pccl",
        "scopeName": "source.pcc",
        "path": "./syntaxes/pccl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "pccl.openCalculator",
        "title": "PCCL: Bit Hesaplayıcıyı Aç",
        "category": "PCCL",
        "icon": {
          "light": "resources/pccl_icon.webp",
          "dark": "resources/pccl_icon.webp"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "pccl.openCalculator",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "PCCL",
      "properties": {
        "pccl.maxNumberOfProblems": {
          "scope": "resource",
          "type": "number",
          "default": 1000,
          "description": "Sunucunun üretebileceği maksimum sorun sayısını kontrol eder."
        },
        "pccl.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "VS Code ile dil sunucusu arasındaki iletişimi izler."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint ./client/src ./server/src --ext .ts,.tsx",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
    "test": "sh ./scripts/e2e.sh"
  },
  "devDependencies": {
    "@types/mocha": "^9.1.0",
    "@types/node": "^16.11.7",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "eslint": "^8.35.0",
    "mocha": "^9.2.1",
    "typescript": "^5.0.2"
  }
}
